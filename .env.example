# tidewall-bench environment configuration.
# Copy to .env and populate the section for whichever provider you want to test.

# --- Tidewall (default target — coming soon) ----------------------------
# TIDEWALL_BASE_URL="http://localhost:8080"
# TIDEWALL_TOKEN=""

# --- CrowdStrike AIDR (preserved from upstream) -------------------------
# Set the deployment base URL (include port if non-default).
CS_AIDR_BASE_URL_TEMPLATE="https://api.eu-1.crowdstrike.com/aidr/aiguard"
# Service token from your AIDR API Collector (Falcon AIDR Console).
CS_AIDR_TOKEN=""

# --- Pangea AI Guard (preserved from upstream) --------------------------
# PANGEA_TOKEN=""
# PANGEA_DOMAIN=""
